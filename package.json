{
  "name": "openclaw-self-evolution",
  "version": "0.1.0",
  "description": "Self-evolution pipeline for OpenClaw skills using genetic algorithms and LLM-as-judge fitness evaluation",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:watch": "jest --watch",
    "setup:python": "pip install -r python/requirements.txt",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
